TELEGRAM_BOT_TOKEN=replace_with_botfather_token
ALLOWED_TELEGRAM_USER_IDS=193060672

# AI provider
# OPENAI_API_KEY is used first for text, image understanding, image generation, and Whisper.
# OPENROUTER_API_KEY is an optional fallback for text + image understanding.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_FAST=~openai/gpt-latest
OPENROUTER_MODEL_HEAVY=~openai/gpt-latest
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL_FAST=gpt-4.1-mini
OPENAI_MODEL_HEAVY=gpt-4.1
OPENAI_IMAGE_MODEL=gpt-image-2
LOCAL_WHISPER_MODEL=base

# Optional runtime behavior
BOT_NAME=Amy
LOW_TOKEN_MODE=true
DAILY_BRIEFING_ENABLED=false
DAILY_BRIEFING_HOUR=8
DAILY_BRIEFING_MINUTE=45

# Optional scraping
APIFY_API_TOKEN=

# Optional AI deck provider / future integrations
GAMMA_API_KEY=

# Optional: override the service name on your VPS (default: amy-vps-bot)
HERMES_SERVICE_NAME=hermes-agent
BOT_SERVICE_NAME=amy-vps-bot
